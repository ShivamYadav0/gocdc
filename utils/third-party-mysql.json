{
    "name": "third-party-mysql",
    "config": {
      "connector.class": "io.debezium.connector.mysql.MySqlConnector",
      "tasks.max": "1",
      "database.hostname": "127.0.0.1",
      "database.port": "3306",
      "database.user": "root",
      "database.password": "debezium",
      "database.server.id": "999001",
      "topic.prefix": "remote_inventory",
      "database.include.list": "inventory",
      "table.include.list": "inventory.histalarms",
      "schema.history.internal.store.only.captured.tables.ddl": "true",
      "snapshot.mode": "initial",
      "snapshot.locking.mode": "none", 
      "snapshot.fetch.size": "50000",
      "connect.timeout.ms": "30000",
      "topic.creation.default.replication.factor": "1",
      "topic.creation.default.partitions": "1",
      "topic.creation.enable": "true",
      "schema.history.internal.kafka.bootstrap.servers": "kafka:9092",
      "schema.history.internal.kafka.topic": "schema-changes.inventory_histalarm",
      "max.batch.size": "20480",       
        "max.queue.size": "81920",        
        "poll.interval.ms": "500",       
        

        "producer.override.compression.type": "lz4",  
        "producer.override.batch.size": "524288",   
        "producer.override.linger.ms": "50"
    }
  }